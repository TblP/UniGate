-declare -A SERVICE_DNS
-declare -A SERVICE_DNS_SEARCH
+SERVICE_NAMES=( )
+SERVICE_DNS=( )
+SERVICE_DNS_SEARCH=( )
+
+service_index() {
+	local needle="$1" i
+	SERVICE_INDEX=-1
+	for ((i=0; i<${#SERVICE_NAMES[@]}; i++)); do
+		[[ ${SERVICE_NAMES[$i]} == "$needle" ]] && { SERVICE_INDEX=$i; return; }
+	done
+}
+
+array_contains() {
+	local needle="$1" value
+	shift
+	for value in "$@"; do
+		[[ $value == "$needle" ]] && return 0
+	done
+	return 1
+}
 collect_new_service_dns() {
-	local service get_response
-	local -A found_services
+	local service get_response i
+	local found_services=( ) next_names=( ) next_dns=( ) next_search=( )
 	{ read -r _ && while read -r service; do
 		[[ $service == "*"* ]] && service="${service:1}"
-		found_services["$service"]=1
-		[[ -n ${SERVICE_DNS["$service"]} ]] && continue
+		found_services+=( "$service" )
+		service_index "$service"
+		if [[ $SERVICE_INDEX -lt 0 ]]; then
+			SERVICE_NAMES+=( "$service" )
+			SERVICE_DNS+=( "" )
+			SERVICE_DNS_SEARCH+=( "" )
+			SERVICE_INDEX=$((${#SERVICE_NAMES[@]} - 1))
+		fi
+		[[ -n ${SERVICE_DNS[$SERVICE_INDEX]} ]] && continue
 		get_response="$(cmd networksetup -getdnsservers "$service")"
 		[[ $get_response == *" "* ]] && get_response="Empty"
-		[[ -n $get_response ]] && SERVICE_DNS["$service"]="$get_response"
+		[[ -n $get_response ]] && SERVICE_DNS[$SERVICE_INDEX]="$get_response"
 		get_response="$(cmd networksetup -getsearchdomains "$service")"
 		[[ $get_response == *" "* ]] && get_response="Empty"
-		[[ -n $get_response ]] && SERVICE_DNS_SEARCH["$service"]="$get_response"
+		[[ -n $get_response ]] && SERVICE_DNS_SEARCH[$SERVICE_INDEX]="$get_response"
 	done; } < <(networksetup -listallnetworkservices)
 
-	for service in "${!SERVICE_DNS[@]}"; do
-		if ! [[ -n ${found_services["$service"]} ]]; then
-			unset SERVICE_DNS["$service"]
-			unset SERVICE_DNS_SEARCH["$service"]
-		fi
+	for ((i=0; i<${#SERVICE_NAMES[@]}; i++)); do
+		array_contains "${SERVICE_NAMES[$i]}" "${found_services[@]}" || continue
+		next_names+=( "${SERVICE_NAMES[$i]}" )
+		next_dns+=( "${SERVICE_DNS[$i]}" )
+		next_search+=( "${SERVICE_DNS_SEARCH[$i]}" )
 	done
+	SERVICE_NAMES=( "${next_names[@]}" )
+	SERVICE_DNS=( "${next_dns[@]}" )
+	SERVICE_DNS_SEARCH=( "${next_search[@]}" )
 }
 
